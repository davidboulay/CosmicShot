[Desktop Entry]
Type=Application
Name=CosmicShot
GenericName=Screenshot & Annotation
Comment=Capture, annotate, and share screenshots — CleanShot-style for COSMIC
Exec=cosmicshot tray
Icon=cosmicshot
Terminal=false
Categories=Graphics;Utility;
Keywords=screenshot;capture;annotate;screen;
StartupNotify=false
StartupWMClass=cosmicshot
Actions=Region;Screen;Window;

[Desktop Action Region]
Name=Capture Region
Exec=cosmicshot region

[Desktop Action Screen]
Name=Capture Screen
Exec=cosmicshot screen

[Desktop Action Window]
Name=Capture Window (COSMIC picker)
Exec=cosmicshot window
